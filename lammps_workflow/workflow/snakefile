import numpy as np
from pathlib import Path
import json

# General
molality = [1, 2, 4]
identifiers = [f"{m}_m" for m in molality]  # sample identifier for each type of system
total_cation = [int(10 * m) for m in molality]  # Total number of cations to put inside
total_anion = [int(2 * cat) for cat in total_cation]
total_dimer = [1, 1, 1]  # anion-cation-anion
total_monomer = [1, 1, 1]  # cation-anion
total_water = [555 for m in molality]

BOX_DIMENSION = 30.0  # In Angstroms

# Input XYZ files required for PACKMOL
# if using relative paths they should be relative to the workflow folder
WATER_MODEL = "tip4p_2005"
PACKMOL_CATION_INP = f"../resources/packmol/fe.xyz"
PACKMOL_ANION_INP = f"../resources/packmol/cl.xyz"
PACKMOL_WATER_INP = f"../resources/packmol/{WATER_MODEL}/{WATER_MODEL}_water.xyz"
PACKMOL_MONOMER_INP = f"../resources/packmol/fe_cl.xyz"
PACKMOL_DIMER_INP = f"../resources/packmol/fe_cl2.xyz"
# Resource and input files, variables etc for Moltemplate
# Important: always use absolute paths for moltemplate
MOLTEMPLATE_CATION_INP = Path(f"../resources/moltemplate/fe_ions.lt").resolve()
MOLTEMPLATE_ANION_INP = Path(f"../resources/moltemplate/cl.lt").resolve()
MOLTEMPLATE_WATER_INP = Path(f"../resources/moltemplate/tip4p_2005.lt").resolve()

input_dict = {}

for (
    i_molal,
    n_cations_tot,
    n_anions_tot,
    n_wat_tot,
    n_monomer,
    n_dimer,
    sample_id,
) in zip(
    molality,
    total_cation,
    total_anion,
    total_water,
    total_monomer,
    total_dimer,
    identifiers,
):
    num_free_cation = n_cations_tot - n_monomer - n_dimer
    num_free_wat = n_wat_tot
    num_free_anion = n_anions_tot - n_monomer - 2 * n_dimer
    input_dict[sample_id] = {
        "molality": i_molal,
        "n_monomer": n_monomer,
        "n_cations": num_free_cation,
        "n_anions": num_free_anion,
        "n_wat": num_free_wat,
        "n_dimer": n_dimer,
    }

SAMPLES = list(input_dict.keys())


rule all:
    input:
        expand("results/moltemplate/{sample}/system.data", sample=SAMPLES),


rule create_data:
    localrule: True
    input:
        packmol_cation_file=PACKMOL_CATION_INP,
        packmol_anion_file=PACKMOL_ANION_INP,
        packmol_water_file=PACKMOL_WATER_INP,
        moltemplate_cation_file=MOLTEMPLATE_CATION_INP,
        moltemplate_anion_file=MOLTEMPLATE_ANION_INP,
        moltemplate_water_file=MOLTEMPLATE_WATER_INP,
    params:
        packmol_monomer_file=PACKMOL_MONOMER_INP,
        packmol_dimer_file=PACKMOL_DIMER_INP,
        tolerance=2.0,
        packmol_output_xyz="results/packmol/{sample}/system.xyz",
        n_wat=lambda wc: input_dict[wc.sample]["n_wat"],
        n_monomer=lambda wc: input_dict[wc.sample]["n_monomer"],
        n_dimer=lambda wc: input_dict[wc.sample]["n_dimer"],
        n_free_cations=lambda wc: input_dict[wc.sample]["n_cations"],
        n_free_anions=lambda wc: input_dict[wc.sample]["n_anions"],
        x_box_length=BOX_DIMENSION,
        y_box_length=BOX_DIMENSION,
        z_box_length=BOX_DIMENSION,
        cation_radius=1.75,  # Generally the radius is at least half the tolerance but you can increase it 
        anion_radius=1.75,
        seed=-1,
    output:
        packmol="results/packmol/{sample}/system.xyz",
        moltemplate="results/moltemplate/{sample}/system.data",
    script:
        "scripts/create_datafile.py"
