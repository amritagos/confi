# All atoms from different molecules will be at least 2.0 Angstroms apart
# from each other at the solution.

tolerance {{params.tolerance}}

# The files are in the simple Molden-xyz format

filetype {{input.filetype.value}}

# The name of the output file.

output {{params.system_file}}

# All molecules will be set to stay in the box defined by minimum and maximum coordinates

pbc 0. 0. 0. {{params.x_box_length}} {{params.y_box_length}} {{params.z_box_length}}

seed {{params.seed}}

{% if params.n_monomer > 0 %}
structure {{params.monomer_file}}
  number {{params.n_monomer}}
  radius {{params.monomer_radius}}
end structure
{% endif %}

{% if params.n_dimer > 0 %}
structure {{params.dimer_file}}
  number {{params.n_dimer}}
  radius {{params.dimer_radius}}
end structure
{% endif %}

{% if params.n_free_cations > 0 %}
structure {{input.cation_file}}
  number {{params.n_free_cations}}
  radius {{params.cation_radius}}
end structure
{% endif %}

{% if params.n_free_anions > 0 %}
structure {{input.anion_file}}
  number {{params.n_free_anions}}
  radius {{params.anion_radius}}
end structure
{% endif %}

{% if params.n_wat > 0 %}
structure {{input.water_file}}
  number {{params.n_wat}}
end structure
{% endif %}